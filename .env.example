# =============================================================================
# CREDENCIALES DE BINANCE
# =============================================================================
# Obtén tus API keys en: https://www.binance.com/en/my/settings/api-management
# IMPORTANTE: Activa solo permisos de "Spot & Margin Trading" y "Read"
# NUNCA habilites permisos de retiro

BINANCE_API_KEY=tu_api_key_aqui
BINANCE_API_SECRET=tu_api_secret_aqui

# =============================================================================
# TELEGRAM BOT
# =============================================================================
# 1. Habla con @BotFather en Telegram
# 2. Envía /newbot y sigue las instrucciones
# 3. Copia el token que te da
# 4. Para obtener tu chat_id, habla con @userinfobot

TELEGRAM_BOT_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui
