# =============================================================================
# CREDENCIALES DE BINANCE
# =============================================================================
# Obtén tus API keys en: https://www.binance.com/en/my/settings/api-management
# IMPORTANTE: Activa solo permisos de "Spot & Margin Trading" y "Read"
# NUNCA habilites permisos de retiro

BINANCE_API_KEY=tu_api_key_de_binance_aqui
BINANCE_API_SECRET=tu_api_secret_de_binance_aqui

# =============================================================================
# TELEGRAM BOT
# =============================================================================
# Crea tu bot con @BotFather en Telegram
# Obtén tu chat_id enviando un mensaje a @userinfobot

TELEGRAM_BOT_TOKEN=tu_token_de_telegram_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui
